# Copia questo file in .env.local per lo sviluppo in locale.
# La chiave OpenChargeMap e opzionale, ma consigliata per evitare limiti/rifiuti API.
OCM_API_KEY=

# Opzionali: feed tariffe EV personalizzato.
# EV_TARIFFS_URL=https://example.com/ev-tariffs.json
# EV_TARIFFS_JSON=[{"operator":"Esempio","prices":[{"label":"AC","eurPerKwh":0.49}]}]

# Porta del server locale, default 3000.
# PORT=3000
