# Copia questo file in .env.local per lo sviluppo in locale.
# La chiave OpenChargeMap e' consigliata: senza chiave l'API puo' rifiutare le richieste.
OCM_API_KEY=incolla_qui_la_tua_chiave_openchargemap

# Opzionali: feed tariffe EV personalizzato.
# EV_TARIFFS_URL=https://example.com/ev-tariffs.json
# EV_TARIFFS_JSON=[{"operator":"Esempio","prices":[{"label":"AC","eurPerKwh":0.49}]}]


# Opzionali: feed colonnine aggiuntivi autorizzati o open-data.
# Accettano JSON o CSV con campi come lat/lon, nome, indirizzo, gestore, potenza, stato.
# EV_STATIONS_URL=https://example.com/ev-stations.json
# EV_STATIONS_URLS=https://example.com/source-a.csv,https://example.com/source-b.json
# PUN_STATIONS_URL=https://example.com/pun-export.csv
# PLENITUDE_STATIONS_URL=https://example.com/plenitude-authorized-feed.json
# ELECTROMAPS_STATIONS_URL=https://example.com/electromaps-authorized-feed.json

# Porta del server locale, default 3000.
# PORT=3000
